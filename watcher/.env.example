# Master server URL (use ngrok URL or local URL)
MASTER_URL=http://localhost:8000

# Folder to watch for completed downloads (qBittorrent download folder)
WATCH_FOLDER=C:\Audiobooks

# Admin credentials (same as master server)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ----- Book Searcher Settings -----
# Audiobook website credentials
SITE_URL=https://audiobookbay.lu
SITE_USERNAME=your_email@example.com
SITE_PASSWORD=your_password_here

# qBittorrent Web UI
QBITTORRENT_HOST=http://localhost:8080
QBITTORRENT_USER=your_qbittorrent_username
QBITTORRENT_PASS=your_qbittorrent_password

# ----- Dreame FM Scraper -----
# Optional: API template to resolve episode audio URL (after running dreame_discover.py).
# Use {episode_id} or {id} placeholder, e.g. https://api.dreamefm.com/episode/{episode_id}/stream
# DREAME_EPISODE_AUDIO_API=
# Delay in seconds between episode downloads (rate limiting)
# DREAME_DOWNLOAD_DELAY=1.0
